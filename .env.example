# ═══════════════════════════════════════════════════
# BNB Turnkey QC — Zero-Cost Edition
# ═══════════════════════════════════════════════════

PORT=3001
NODE_ENV=production

# AI Engine: "gemini" (free) or "claude" (needs API key)
AI_ENGINE=gemini

# Gemini (FREE — get key at aistudio.google.com)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

# Claude (OPTIONAL — $5 free credits at console.anthropic.com)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20241022

# Webhook auth key (make up a random string)
WEBHOOK_SECRET_KEY=change-me-to-something-random

# Daily budget cap (0 = unlimited for free tier)
DAILY_BUDGET_USD=0
